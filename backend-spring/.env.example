# ============ DATABASE (Supabase PostgreSQL) ============
# Supabase предоставляет PostgreSQL БД
SPRING_DATASOURCE_URL=jdbc:postgresql://db.YOUR_PROJECT_ID.supabase.co:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=YOUR_SUPABASE_PASSWORD

# ============ FIREBASE (Authentication ONLY) ============
# Firebase используется ТОЛЬКО для аутентификации
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_DATABASE_URL=https://YOUR_FIREBASE_PROJECT_ID.firebaseio.com
FIREBASE_CREDENTIALS_PATH=/config/firebase-adminsdk.json

# ============ SUPABASE (REST API + Real-time) ============
# URL вашего Supabase проекта
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# Anon публичный ключ (для клиента)
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Service Role ключ (для сервера, СЕКРЕТНЫЙ!)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ============ GROQ (Cody AI companion) ============
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ============ SERVER ============
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api/v1

# ============ LOGGING ============
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_CODEQUEST=DEBUG


